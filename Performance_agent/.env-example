# Example environment variables for LatencyFixer AI
# Copy this to .env and fill values as needed.

# API server
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1

# Frontend (used by Vite during development)
VITE_API_URL=http://localhost:8000

# LLM provider and API keys
# For Anthropic (Claude) - used by BenchmarkRunner if present
ANTHROPIC_API_KEY=
# For OpenAI (if used)
OPENAI_API_KEY=

# AWS Bedrock (if using AWS provider)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BEDROCK_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
LLM_PROVIDER=anthropic  # or 'aws' or 'openai'

# Behavior flags
DEBUG=false
VERBOSE=false

# Scoring weights (optional overrides)
WEIGHT_LATENCY_GAIN=0.35
WEIGHT_ACCURACY=0.25
WEIGHT_STABILITY=0.15
WEIGHT_CLARITY=0.15
WEIGHT_CONTEXT_EFFICIENCY=0.10

# Dependency/context limits
MAX_DEPENDENCY_DEPTH=2
MAX_CONTEXT_TOKENS=50000

# Severity thresholds (ms)
THRESHOLD_CRITICAL=500
THRESHOLD_HIGH=200
THRESHOLD_MEDIUM=50
THRESHOLD_LOW=10

# Local dev helpers
# If you have local Bedrock emulator or proxies, set these appropriately
# LOCAL_BEDROCK_ENDPOINT=

# NOTE: Do NOT commit real API keys to version control. Store them securely.
